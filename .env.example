# Database Configuration
DATABASE_URL=postgres://user:password@localhost:5432/dropsandgrinds
DATABASE_READ_REPLICA_URL=postgres://user:password@localhost:5432/dropsandgrinds

# Logging Configuration
LOG_DIR=logs
LOG_FORMAT=text  # text or json
LOG_LEVEL=info  # debug, info, warn, error
POSTGRES_DB=dropsandgrinds
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PASSWORD_FILE=./secrets/postgres_password.txt
JWT_SECRET_FILE=./secrets/jwt_secret.txt
SENTRY_DSN_FILE=./secrets/sentry_dsn.txt
STEAM_API_KEY_FILE=./secrets/steam_api_key.txt

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_change_in_production

# Sentry Configuration (optional)
SENTRY_DSN=your_sentry_dsn

# Server Configuration
PORT=8080

# Steam API Configuration
STEAM_API_KEY=your_steam_api_key

# Meilisearch Configuration (optional)
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=your-meilisearch-master-key

# Google OAuth Configuration (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Email/SMTP Configuration for notifications
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=noreply@dropsandgrinds.com

# Production Configuration
ENVIRONMENT=development  # development, staging, production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting Configuration
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=1m

# Cache TTL Configuration (in seconds)
CACHE_GAME_PRICES_TTL=300
CACHE_DEALS_TTL=120
CACHE_GAME_DETAILS_TTL=600
CACHE_SEARCH_RESULTS_TTL=180
CACHE_INDIAN_OFFERS_TTL=1800
CACHE_STORE_HEALTH_TTL=60

# Scheduler Configuration
PRICE_REFRESH_INTERVAL=15m
REVIEW_REFRESH_INTERVAL=24h
PRICE_DROP_NOTIFICATION_INTERVAL=30m
